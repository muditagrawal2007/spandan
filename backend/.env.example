# ============================================================================
# Spandan backend — environment configuration template
# Copy to `.env` and fill in. Values shown are the in-code defaults (used when
# the variable is unset) unless noted otherwise. Most of the tuning / cache /
# buffer vars below are OPTIONAL — omit them and the default applies (that's why
# a working .env is much shorter than this file). The ones normally set:
# PORT, NODE_ENV, FRONTEND_URL, CORS_ORIGINS, MONGODB_URI, JWT_SECRET, an AI
# provider key, SMTP_*, REDIS_URL (for multi-instance), and RESEARCH_API_KEY.
# ============================================================================

# --- Server ----------------------------------------------------------------
# Port the backend listens on. This project runs on 7001 (production pm2 runs
# two instances on 7001 / 7002). Note: the code's bare fallback when PORT is
# unset is 3001, but the app is always started with PORT=7001.
PORT=7001

# Environment. MUST be exactly "production" in prod — that value gates off the
# hot-path debug logging (utils/debug.js) and hides internal error detail.
# Anything else (e.g. "dev") is treated as development (verbose logs, error
# detail in responses).
NODE_ENV=dev

# Path the app is mounted under, e.g. "/spandan" in production, empty for local.
BASE_PATH=

# --- URLs / CORS -----------------------------------------------------------
# Frontend URL (for CORS + password-reset / email links). Include the base path.
FRONTEND_URL=http://localhost:5173/spandan

# Comma-separated allowed CORS origins (no paths). Any localhost origin is also
# allowed automatically. Production: https://your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:8080

# --- MongoDB ---------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/spandan
MONGO_MAX_POOL_SIZE=200
MONGO_MIN_POOL_SIZE=10

# --- Redis (optional; enables multi-instance mode) -------------------------
# When set, the socket.io Redis adapter is attached so io.to(room).emit reaches
# clients on ALL backend instances (required to run more than one instance),
# and rate limiting + live-broadcast coordination become cross-instance.
# Leave empty for a single-instance / local setup.
REDIS_URL=

# --- Auth ------------------------------------------------------------------
# Generate a strong random string for production.
JWT_SECRET=your-super-secret-jwt-string-here
JWT_EXPIRY=7d
BCRYPT_COST=10
AUTH_CACHE_MAX=20000
AUTH_CACHE_TTL_MS=60000

# --- AI providers (question generation) ------------------------------------
MINIMAX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Max concurrent generation jobs the worker processes.
GENERATION_CONCURRENCY=2

# --- Email (password reset & welcome emails) -------------------------------
# Gmail SMTP: enable 2FA and use an App Password as SMTP_PASSWORD.
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
# Optional alternative to Gmail SMTP.
RESEND_API_KEY=

# --- Transcription service (separate faster-whisper process) ---------------
# URL the backend proxies audio to for speech-to-text.
TRANSCRIPTION_SERVICE_URL=http://127.0.0.1:3003
# Port used when starting the bundled transcription server locally.
TRANSCRIPTION_PORT=3002
TRANSCRIBE_TIMEOUT_MS=30000

# --- Live updates / leaderboard tuning -------------------------------------
# Throttle window for the cheap live answer-count broadcast (ms).
LIVE_UPDATE_THROTTLE_MS=1500
# The ranked leaderboard is DEFERRED: it recomputes+broadcasts only after the
# room has been quiet (no new answers) for this many ms (drains the burst).
LEADERBOARD_IDLE_MS=12000
# How many top rows the live leaderboard broadcast includes.
LEADERBOARD_TOP_N=20

# --- Response write buffering (optional, default OFF) ----------------------
# When "on", student answers are batched via insertMany instead of one save()
# each. Trades a small durability/read-after-write window for less DB pressure
# under a large synchronized burst. See services/responseBuffer.js.
RESPONSE_BATCH=off
RESPONSE_FLUSH_MS=250
RESPONSE_FLUSH_MAX=500

# --- Hot-path read caches --------------------------------------------------
# Short TTLs for the membership + question caches used by POST /responses.
MEMBER_CACHE_TTL_MS=60000
QUESTION_CACHE_TTL_MS=30000

# --- Research export API ---------------------------------------------------
# API key for GET /api/research/sessions (X-Research-Key header). REQUIRED in
# production — if unset the route falls back to an insecure dev default. Share
# the real key with the researcher out-of-band, never commit it.
RESEARCH_API_KEY=
