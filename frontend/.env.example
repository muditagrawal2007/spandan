# Central configuration - change BASE_PATH to update entire app URL structure
# Empty for local dev (works with Vite proxy), /spandan for production server with nginx base path
VITE_BASE_PATH=/spandan

# Optional: Override socket URL/path
# URL defaults to window.location.origin
# Path defaults to /socket.io, which is the current production Socket.IO route.
# VITE_SOCKET_URL=http://localhost:8080
VITE_SOCKET_PATH=/socket.io
